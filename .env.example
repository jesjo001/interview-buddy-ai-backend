NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/interview-prep-ai
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=0
JWT_SECRET=your-super-secret-jwt-key
JWT_REFRESH_SECRET=your-refresh-token-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

OPENAI_API_KEY=your-openai-api-key

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
S3_BUCKET=interview-prep-uploads

# Redis is not supported in this deployment setup.
# For caching, an in-memory solution (node-cache) will be used.
# For job queue, a simple in-memory queue will be implemented.
# REDIS_HOST=localhost
# REDIS_PORT=6379

SENDGRID_API_KEY=your-sendgrid-key
FROM_EMAIL=noreply@interviewprepai.com

FLUTTERWAVE_SECRET_KEY=your-flutterwave-secret-key
FLUTTERWAVE_WEBHOOK_HASH=your-flutterwave-webhook-hash
FLUTTERWAVE_CURRENCY=USD
FLUTTERWAVE_PLAN_AMOUNTS_JSON={"pro":29,"enterprise":99}
FLUTTERWAVE_PLAN_VALIDITY_DAYS_JSON={"pro":30,"enterprise":365}

GOOGLE_CLOUD_TTS_KEY=your-gcloud-key

SENTRY_DSN=your-sentry-dsn

FRONTEND_URL=http://localhost:3000,http://localhost:8080,https://your-production-frontend.com
